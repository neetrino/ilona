{
  "name": "@ilona/database",
  "version": "0.1.0",
  "private": true,
  "description": "Prisma database client for Ilona English Center",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "prisma generate && tsc && node scripts/copy-generated-to-dist.js",
    "dev": "tsc --watch",
    "prepare": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "node scripts/prisma-with-root-env.cjs db push",
    "db:migrate": "node scripts/migrate-deploy-with-resolve.js",
    "db:migrate:resolve-planned-absences-rollback": "prisma migrate resolve --rolled-back 20260331120000_add_planned_absences",
    "db:apply-teacher-approved": "node scripts/apply-teacher-approved-at.js",
    "db:migrate:dev": "node scripts/prisma-with-root-env.cjs migrate dev",
    "db:studio": "node scripts/prisma-with-root-env.cjs studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset",
    "db:apply-obligations": "node scripts/apply-migration.js",
    "db:add-lesson-rate": "dotenv -e ../../.env.local -- tsx scripts/add-lesson-rate-column.ts",
    "db:add-color-hex": "tsx scripts/apply-color-hex-migration.ts",
    "db:reconcile-phase0": "tsx scripts/reconcile-phase0-schema.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "dotenv": "^17.2.3",
    "prisma": "^5.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.5.4"
  }
}

