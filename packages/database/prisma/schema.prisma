generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                      String            @id @default(cuid())
  email                   String            @unique
  passwordHash            String
  firstName               String
  lastName                String
  phone                   String?
  avatarUrl               String?
  role                    UserRole
  status                  UserStatus        @default(ACTIVE)
  lastLoginAt             DateTime?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  chatParticipants        ChatParticipant[]
  crmLeadsAssignedManager CrmLead[]         @relation("LeadAssignedManager")
  crmLeadsCreated         CrmLead[]         @relation("LeadCreatedBy")
  managerProfile          ManagerProfile?
  sentMessages            Message[]         @relation("SentMessages")
  notifications           Notification[]
  markedAttendances       Attendance[]      @relation("AttendanceMarkedBy")
  student                 Student?
  teacher                 Teacher?

  @@index([email])
  @@index([role])
  @@map("users")
}

model Center {
  id              String           @id @default(cuid())
  name            String
  address         String?
  phone           String?
  email           String?
  description     String?
  colorHex        String?
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  crmLeads        CrmLead[]
  groups          Group[]
  managerProfiles ManagerProfile[]
  teacherCenters  TeacherCenter[]

  @@map("centers")
}

model ManagerProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  centerId  String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  center    Center   @relation(fields: [centerId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("manager_profiles")
}

model Group {
  id                   String    @id @default(cuid())
  name                 String
  level                String?
  description          String?
  maxStudents          Int       @default(8)
  centerId             String
  teacherId            String?
  substituteTeacherId  String?
  schedule             Json?
  isActive             Boolean   @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  chat                 Chat?
  crmLeads             CrmLead[]
  center               Center    @relation(fields: [centerId], references: [id], onDelete: Cascade)
  teacher              Teacher?  @relation(fields: [teacherId], references: [id])
  substituteTeacher    Teacher?  @relation("GroupSubstitute", fields: [substituteTeacherId], references: [id])
  lessons              Lesson[]
  students             Student[]
  studentHistoryEntries StudentGroupHistory[]
  dailyPlans           DailyPlan[]
  recordingItems       RecordingItem[]

  @@index([centerId])
  @@index([teacherId])
  @@index([substituteTeacherId])
  @@map("groups")
}

model Teacher {
  id                  String         @id @default(cuid())
  userId              String         @unique
  bio                 String?
  specialization     String?
  hourlyRate          Decimal        @db.Decimal(10, 2)
  lessonRateAMD       Decimal?       @db.Decimal(10, 2)
  videoUrl            String?
  workingDays         String[]
  workingHours        Json?
  hireDate            DateTime       @default(now())
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  crmLeads            CrmLead[]
  deductions          Deduction[]
  feedbacks           Feedback[]
  groups              Group[]
  substituteForGroups Group[]        @relation("GroupSubstitute")
  lessons             Lesson[]
  salaryRecords       SalaryRecord[]
  students            Student[]
  user                User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  centerLinks         TeacherCenter[]
  notes               TeacherNote[]
  dailyPlans          DailyPlan[]

  @@map("teachers")
}

model TeacherCenter {
  id        String   @id @default(cuid())
  teacherId String
  centerId  String
  createdAt DateTime @default(now())
  teacher   Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  center    Center   @relation(fields: [centerId], references: [id], onDelete: Cascade)

  @@unique([teacherId, centerId])
  @@index([teacherId])
  @@index([centerId])
  @@map("teacher_centers")
}

model TeacherNote {
  id        String   @id @default(cuid())
  teacherId String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  teacher   Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@map("teacher_notes")
}

model Student {
  id              String         @id @default(cuid())
  userId          String         @unique
  groupId         String?
  teacherId       String?
  currentStreak   Int            @default(0)
  age             Int?
  dateOfBirth     DateTime?
  firstLessonDate DateTime?
  status          StudentStatus  @default(ACTIVE)
  riskLabel       RiskLabel      @default(NONE)
  parentName      String?
  parentPhone     String?
  parentEmail     String?
  parentPassportInfo String?
  monthlyFee      Decimal        @db.Decimal(10, 2)
  enrolledAt      DateTime       @default(now())
  registerDate    DateTime?
  notes           String?
  receiveReports  Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  leadId          String?        @unique
  attendances     Attendance[]
  feedbacks       Feedback[]
  payments        Payment[]
  group           Group?         @relation(fields: [groupId], references: [id])
  lead            CrmLead?       @relation(fields: [leadId], references: [id])
  teacher         Teacher?       @relation(fields: [teacherId], references: [id])
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupHistory    StudentGroupHistory[]
  plannedAbsences PlannedAbsence[]
  recordingItems  RecordingItem[]
  notesList       StudentNote[]

  @@index([groupId])
  @@index([teacherId])
  @@index([leadId])
  @@index([status])
  @@index([riskLabel])
  @@map("students")
}

model StudentNote {
  id        String   @id @default(cuid())
  studentId String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("student_notes")
}

/// Student-reported absence for a future class day (calendar date).
model PlannedAbsence {
  id        String   @id @default(cuid())
  studentId String
  date      DateTime @db.Date
  status    String   @default("planned_absence")
  comment   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
  @@index([studentId])
  @@index([date])
  @@map("planned_absences")
}

model StudentGroupHistory {
  id        String   @id @default(cuid())
  studentId String
  groupId   String
  joinedAt  DateTime @default(now())
  leftAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([groupId])
  @@index([studentId, leftAt])
  @@map("student_group_histories")
}

model Lesson {
  id                 String       @id @default(cuid())
  groupId            String
  teacherId          String
  scheduledAt        DateTime
  duration           Int          @default(60)
  topic              String?
  description        String?
  status             LessonStatus @default(SCHEDULED)
  vocabularySent     Boolean      @default(false)
  vocabularySentAt   DateTime?
  feedbacksCompleted Boolean      @default(false)
  absenceMarked      Boolean      @default(false)
  absenceMarkedAt    DateTime?
  voiceSent          Boolean      @default(false)
  voiceSentAt        DateTime?
  textSent           Boolean      @default(false)
  textSentAt         DateTime?
  completedAt        DateTime?
  notes              String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  attendances        Attendance[]
  feedbacks          Feedback[]
  group              Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  teacher            Teacher      @relation(fields: [teacherId], references: [id])
  dailyPlan          DailyPlan?
  recordingItems     RecordingItem[]

  @@index([groupId])
  @@index([teacherId])
  @@index([scheduledAt])
  @@index([status])
  @@index([groupId, scheduledAt])
  @@map("lessons")
}

model Attendance {
  id          String       @id @default(cuid())
  lessonId    String
  studentId   String
  markedById  String?
  isPresent   Boolean
  absenceType AbsenceType?
  note        String?
  markedAt    DateTime     @default(now())
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  lesson      Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  markedBy    User?        @relation("AttendanceMarkedBy", fields: [markedById], references: [id], onDelete: SetNull)
  student     Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([lessonId, studentId])
  @@index([lessonId])
  @@index([studentId])
  @@index([markedById])
  @@index([isPresent])
  @@map("attendances")
}

model Feedback {
  id            String   @id @default(cuid())
  lessonId      String
  studentId     String
  teacherId     String
  content       String
  rating        Int?
  strengths     String?
  improvements  String?
  // Phase 9 — structured feedback form fields. Existing free-form
  // `content` is kept for backward compatibility with historic entries.
  level         CefrLevel?
  grammarTopics String[]      @default([])
  skills        String[]      @default([])
  skillsNote    String?
  participation Int?          // 1..5 rating; null = not rated
  progress      String?
  encouragement String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lesson        Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher       Teacher  @relation(fields: [teacherId], references: [id])

  @@unique([lessonId, studentId])
  @@index([teacherId])
  @@map("feedbacks")
}

model Payment {
  id            String        @id @default(cuid())
  studentId     String
  amount        Decimal       @db.Decimal(10, 2)
  month         DateTime
  dueDate       DateTime
  status        PaymentStatus @default(PENDING)
  paidAt        DateTime?
  paymentMethod String?
  transactionId String?
  receiptUrl    String?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  student       Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, month])
  @@index([studentId])
  @@index([status])
  @@index([month])
  @@map("payments")
}

model SalaryRecord {
  id              String       @id @default(cuid())
  teacherId       String
  month           DateTime
  lessonsCount    Int          @default(0)
  grossAmount     Decimal      @db.Decimal(10, 2)
  totalDeductions Decimal      @default(0) @db.Decimal(10, 2)
  netAmount       Decimal      @db.Decimal(10, 2)
  status          SalaryStatus @default(PENDING)
  paidAt          DateTime?
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  teacher         Teacher      @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, month])
  @@index([status])
  @@map("salary_records")
}

model Deduction {
  id         String          @id @default(cuid())
  teacherId  String
  lessonId   String?
  reason     DeductionReason
  amount     Decimal         @db.Decimal(10, 2)
  percentage Decimal?        @db.Decimal(5, 2)
  note       String?
  appliedAt  DateTime        @default(now())
  createdAt  DateTime        @default(now())
  teacher    Teacher         @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@index([reason])
  @@map("deductions")
}

model Chat {
  id           String            @id @default(cuid())
  type         ChatType
  name         String?
  groupId      String?           @unique
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  participants ChatParticipant[]
  group        Group?            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  messages     Message[]

  @@index([type])
  @@map("chats")
}

model ChatParticipant {
  id         String    @id @default(cuid())
  chatId     String
  userId     String
  isAdmin    Boolean   @default(false)
  joinedAt   DateTime  @default(now())
  leftAt     DateTime?
  lastReadAt DateTime?
  chat       Chat      @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
  @@index([userId])
  @@map("chat_participants")
}

model Message {
  id        String      @id @default(cuid())
  chatId    String
  senderId  String?
  type      MessageType @default(TEXT)
  content   String?
  fileUrl   String?
  fileName  String?
  fileSize  Int?
  duration  Int?
  metadata  Json?
  isSystem  Boolean     @default(false)
  isEdited  Boolean     @default(false)
  editedAt  DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  chat      Chat        @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender    User?       @relation("SentMessages", fields: [senderId], references: [id])

  @@index([chatId])
  @@index([senderId])
  @@index([type])
  @@index([createdAt])
  @@map("messages")
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  content   String
  data      Json?
  isRead    Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([type])
  @@map("notifications")
}

model SystemSettings {
  id                       String   @id @default(cuid())
  vocabDeductionPercent    Decimal  @default(10) @db.Decimal(5, 2)
  feedbackDeductionPercent Decimal  @default(5) @db.Decimal(5, 2)
  maxUnjustifiedAbsences   Int      @default(3)
  paymentDueDays           Int      @default(5)
  lessonReminderHours      Int      @default(24)
  logoUrl                  String?
  absencePercent           Int      @default(25)
  feedbacksPercent         Int      @default(25)
  voicePercent             Int      @default(25)
  textPercent              Int      @default(25)
  penaltyAbsenceAmd        Decimal  @default(1000) @db.Decimal(10, 2)
  penaltyFeedbackAmd       Decimal  @default(500) @db.Decimal(10, 2)
  penaltyVoiceAmd          Decimal  @default(1000) @db.Decimal(10, 2)
  penaltyTextAmd           Decimal  @default(1000) @db.Decimal(10, 2)
  penaltyDailyPlanAmd      Decimal  @default(1000) @db.Decimal(10, 2)
  updatedAt                DateTime @updatedAt

  @@map("system_settings")
}

model DailyPlan {
  id        String   @id @default(cuid())
  lessonId  String?  @unique
  teacherId String
  groupId   String?
  date      DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  topics    DailyPlanTopic[]
  lesson    Lesson?  @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  teacher   Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  group     Group?   @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@index([teacherId])
  @@index([groupId])
  @@index([date])
  @@map("daily_plans")
}

model DailyPlanTopic {
  id          String              @id @default(cuid())
  dailyPlanId String
  title       String
  order       Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  dailyPlan   DailyPlan           @relation(fields: [dailyPlanId], references: [id], onDelete: Cascade)
  resources   DailyPlanResource[]

  @@index([dailyPlanId])
  @@map("daily_plan_topics")
}

model DailyPlanResource {
  id          String                @id @default(cuid())
  topicId     String
  kind        DailyPlanResourceKind
  title       String
  link        String?
  description String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  topic       DailyPlanTopic        @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@index([topicId])
  @@index([kind])
  @@map("daily_plan_resources")
}

model RecordingItem {
  id          String   @id @default(cuid())
  groupId     String
  studentId   String
  lessonId    String?
  fileUrl     String
  fileName    String?
  durationSec Int?
  recordedAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  group       Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lesson      Lesson?  @relation(fields: [lessonId], references: [id], onDelete: SetNull)

  @@index([groupId])
  @@index([studentId])
  @@index([lessonId])
  @@index([recordedAt])
  @@map("recording_items")
}

model CrmLead {
  id                  String              @id @default(cuid())
  status              CrmLeadStatus       @default(NEW)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  createdByUserId     String
  assignedManagerId   String?
  firstName           String?
  lastName            String?
  phone               String?
  age                 Int?
  dateOfBirth         DateTime?
  parentName          String?
  parentPhone         String?
  parentPassportInfo  String?
  firstLessonDate     DateTime?
  comment             String?
  levelId             String?
  teacherId           String?
  groupId             String?
  centerId            String?
  transferFlag        Boolean             @default(false)
  transferComment     String?
  archivedReason      String?
  source              String?
  notes               String?
  teacherApprovedAt   DateTime?
  activities        CrmLeadActivity[]
  attachments       CrmLeadAttachment[]
  assignedManager   User?               @relation("LeadAssignedManager", fields: [assignedManagerId], references: [id])
  center            Center?             @relation(fields: [centerId], references: [id])
  createdByUser     User                @relation("LeadCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  group             Group?              @relation(fields: [groupId], references: [id])
  teacher           Teacher?            @relation(fields: [teacherId], references: [id])
  student           Student?

  @@index([status])
  @@index([phone])
  @@index([teacherId])
  @@index([groupId])
  @@index([centerId])
  @@index([createdAt])
  @@index([assignedManagerId])
  @@map("crm_leads")
}

model CrmLeadActivity {
  id          String              @id @default(cuid())
  leadId      String
  actorUserId String?
  type        CrmLeadActivityType
  payload     Json?
  createdAt   DateTime            @default(now())
  lead        CrmLead             @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([type])
  @@index([createdAt])
  @@map("crm_lead_activities")
}

model CrmLeadAttachment {
  id        String                @id @default(cuid())
  leadId    String
  type      CrmLeadAttachmentType
  r2Key     String
  mimeType  String?
  size      Int?
  createdAt DateTime              @default(now())
  lead      CrmLead               @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([type])
  @@map("crm_lead_attachments")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String
  oldData   Json?
  newData   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
  @@map("audit_logs")
}

enum UserRole {
  ADMIN
  MANAGER
  TEACHER
  STUDENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum LessonStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  MISSED
  REPLACED
}

enum AbsenceType {
  JUSTIFIED
  UNJUSTIFIED
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

enum SalaryStatus {
  PENDING
  PROCESSING
  PAID
}

enum DeductionReason {
  MISSING_FEEDBACK
  MISSING_VOCABULARY
  LATE_SUBMISSION
  OTHER
}

enum CrmLeadStatus {
  NEW
  FIRST_LESSON
  PAID
  WAITLIST
  ARCHIVE
}

enum CrmLeadActivityType {
  STATUS_CHANGE
  COMMENT
  RECORDING_UPLOADED
  TEACHER_APPROVED
  TEACHER_TRANSFER
  FIELD_UPDATE
}

enum CrmLeadAttachmentType {
  VOICE_RECORDING
  FILE
}

enum ChatType {
  GROUP
  DIRECT
}

enum MessageType {
  TEXT
  VOICE
  IMAGE
  VIDEO
  FILE
  SYSTEM
  VOCABULARY
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  UNGROUPED
  NEW
  RISK
  HIGH_RISK
}

enum RiskLabel {
  NONE
  RISK
  HIGH_RISK
}

enum DailyPlanResourceKind {
  READING
  LISTENING
  WRITING
  SPEAKING
}

enum CefrLevel {
  A1
  A2
  B1
  B2
  C1
  C2
}
